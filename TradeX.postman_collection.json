{
  "info": {
    "name": "TradeX API",
    "description": "Complete API collection for TradeX trading platform backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "tradeId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"Test@1234\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"phone\": \"+919876543210\",\n  \"country\": \"India\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const data = pm.response.json().data;",
              "pm.collectionVariables.set('accessToken', data.accessToken);",
              "pm.collectionVariables.set('refreshToken', data.refreshToken);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"User@123456\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\"\n}" },
            "url": "{{baseUrl}}/auth/forgot-password"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"country\": \"India\"\n}" },
            "url": "{{baseUrl}}/users/me"
          }
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/me/dashboard"
          }
        },
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/notifications"
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "List My Accounts",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const data = pm.response.json().data;",
              "if (data && data[0]) pm.collectionVariables.set('accountId', data[0].id);"
            ]}
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/accounts"
          }
        },
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"pro\",\n  \"currency\": \"USD\",\n  \"leverage\": 1000\n}" },
            "url": "{{baseUrl}}/accounts"
          }
        }
      ]
    },
    {
      "name": "Trading",
      "item": [
        {
          "name": "Open Trade",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "const data = pm.response.json().data;",
              "if (data) pm.collectionVariables.set('tradeId', data.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"symbol\": \"XAUUSD\",\n  \"side\": \"buy\",\n  \"volume\": 0.1,\n  \"stopLoss\": 2300,\n  \"takeProfit\": 2400\n}" },
            "url": "{{baseUrl}}/trades"
          }
        },
        {
          "name": "Get Open Trades",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/trades/open"
          }
        },
        {
          "name": "Close Trade",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/trades/{{tradeId}}/close"
          }
        },
        {
          "name": "Modify Trade SL/TP",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"stopLoss\": 2310,\n  \"takeProfit\": 2390\n}" },
            "url": "{{baseUrl}}/trades/{{tradeId}}/modify"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Deposit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 500,\n  \"method\": \"card\",\n  \"currency\": \"USD\"\n}" },
            "url": "{{baseUrl}}/transactions/deposit"
          }
        },
        {
          "name": "Create Withdrawal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 100,\n  \"method\": \"bank_wire\"\n}" },
            "url": "{{baseUrl}}/transactions/withdraw"
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/transactions?page=1&limit=20"
          }
        }
      ]
    },
    {
      "name": "Markets",
      "item": [
        {
          "name": "Get All Prices",
          "request": { "method": "GET", "url": "{{baseUrl}}/markets/prices" }
        },
        {
          "name": "Get Single Price",
          "request": { "method": "GET", "url": "{{baseUrl}}/markets/price/XAUUSD" }
        },
        {
          "name": "Get Instruments",
          "request": { "method": "GET", "url": "{{baseUrl}}/markets/instruments?category=forex" }
        },
        {
          "name": "Get Candles",
          "request": { "method": "GET", "url": "{{baseUrl}}/markets/candles/EURUSD?interval=1h&limit=50" }
        }
      ]
    },
    {
      "name": "KYC",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "docType", "value": "passport", "type": "text" },
                { "key": "document", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/kyc/upload"
          }
        },
        {
          "name": "Get My Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/kyc"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/stats"
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/admin/users?page=1&limit=20"
          }
        },
        {
          "name": "Approve KYC Document",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"action\": \"approve\"\n}" },
            "url": "{{baseUrl}}/kyc/DOC_ID/review"
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        { "name": "Health", "request": { "method": "GET", "url": "http://localhost:5000/health" } }
      ]
    }
  ]
}
